# Python __pycache__/ *.py[cod] *$py.class *.so .Python .venv/ venv/ env/ *.egg-info/ .pytest_cache/ .ruff_cache/ .coverage htmlcov/  # IDE .vscode/ .idea/ *.swp *.swo  # Project runtime data/raw/ data/normalized/ data/chroma/ data/scheduler/jobs.json data/marketsignal.db data/marketsignal.db-journal data/marketsignal.db-wal data/marketsignal.db-shm *.pid  # Env / secrets .env .env.local .env.*.local  # OS .DS_Store Thumbs.db  # Run artifacts (regenerated on every pipeline run) data/evals/eval_*.json data/reports/battlecard_*.md data/reports/weekly_*.md data/traces/*.json  # Local git config override (contains the GitHub token used by GIT_CONFIG_GLOBAL) .gitconfig.local  # Runtime artifacts data/signalpulse.db data/signalpulse.db-journal data/signalpulse.db-wal data/signalpulse.db-shm run.log  # Backup files *.bak *.bak2 .env.bak  *.bak-*

