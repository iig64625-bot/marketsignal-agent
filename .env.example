# ========================================== # SignalPulse Agent - Environment Variables # Copy to `.env` and fill in your values. # ==========================================  # ---- Runtime ---- APP_ENV=development LOG_LEVEL=INFO TZ=UTC  # ---- Database ---- DATABASE_URL=sqlite:///data/signalpulse.db  # ---- Vector Store ---- CHROMA_PERSIST_DIR=./data/chroma # FastEmbed local model (default, no API key needed) EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5 EMBEDDING_DIM=512 # Set USE_OPENAI_EMBEDDINGS=true to fall back to OpenAI text-embedding-3-small USE_OPENAI_EMBEDDINGS=false  # ---- LLM Provider ---- # Choose one: openai | anthropic | deepseek | gemini | qwen | ollama | custom LLM_PROVIDER=openai LLM_MODEL=gpt-4o-mini  # OpenAI / OpenAI-compatible (e.g. kuaipao.pro, deepseek) OPENAI_API_KEY= OPENAI_BASE_URL=  ANTHROPIC_API_KEY= DEEPSEEK_API_KEY= DEEPSEEK_BASE_URL=https://api.deepseek.com  # Custom OpenAI-compatible endpoint (used when LLM_PROVIDER=custom) LLM_BASE_URL= LLM_API_KEY=  # ---- Crawler ---- HTTP_TIMEOUT=30 HTTP_MAX_RETRIES=3 HTTP_RATE_LIMIT_PER_SEC=1.0 USER_AGENT=SignalPulseAgent/0.1 (+https://github.com/your-repo)  # ---- Report ---- DEFAULT_TIME_WINDOW_DAYS=7 DEFAULT_REPORT_FORMAT=markdown  # ---- CORS ---- # Comma-separated list of allowed origins (overrides the default list in settings.py) # CORS_ORIGINS_STR=http://localhost:8501,http://localhost:3000  # ---- Eval Targets ---- CITATION_COVERAGE_TARGET=0.9 UNSUPPORTED_CLAIM_TARGET=0.1  # ---- Notifications (V4+) ---- # Feishu (Lark) bot webhook FEISHU_WEBHOOK_URL= FEISHU_WEBHOOK_SECRET=  # Email (SMTP) SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASSWORD= NOTIFY_FROM_EMAIL= NOTIFY_TO_EMAILS=  # ---- Scheduling (V4+) ---- # Enable the in-process scheduler that reads schedules.yaml SCHEDULER_ENABLED=true SCHEDULER_POLL_INTERVAL_SEC=60
