# ==========================================
# MarketSignal Agent - Environment Variables
# Copy to `.env` and fill in your values.
# ==========================================

# ---- Runtime ----
APP_ENV=development
LOG_LEVEL=INFO
TZ=UTC

# ---- Database ----
DATABASE_URL=sqlite:///data/marketsignal.db

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- LLM Provider ----
# Choose one: openai | anthropic | deepseek
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Crawler ----
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
HTTP_RATE_LIMIT_PER_SEC=1.0
USER_AGENT=MarketSignalAgent/0.1 (+https://github.com/your-repo)

# ---- Report ----
DEFAULT_TIME_WINDOW_DAYS=7
DEFAULT_REPORT_FORMAT=markdown

# ---- CORS ----
# Comma-separated list of allowed origins (overrides the default list in settings.py)
# CORS_ORIGINS_STR=http://localhost:8501,http://localhost:3000

# ---- Eval Targets ----
CITATION_COVERAGE_TARGET=0.9
UNSUPPORTED_CLAIM_TARGET=0.1
